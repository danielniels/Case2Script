# ── Required ──────────────────────────────────────────────────────────────────
# AES-GCM key for credential decryption (base64 encoded, 32 bytes)
CRED_ENCRYPT_KEY=YOUR_BASE64_ENCODED_KEY_HERE

# ── Optional — defaults shown ─────────────────────────────────────────────────
# Credential API endpoint
CRED_API_URL=http://103.107.205.86:3000/api/config/credential

# Playwright headless mode (false = show browser, true = headless)
HEADLESS=false

# Session idle timeout (seconds)
SESSION_TTL_SECONDS=1800
SESSION_REAPER_INTERVAL=60

# API key for /mcp endpoint (empty = disabled)
MCP_API_KEY=

# Ollama settings
OLLAMA_URL=http://172.16.15.59:11434
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_TIMEOUT=120

# Report submission
SUBMIT_AGENT_URL=http://172.16.12.136:3000/api/running/submit-agent
SUBMIT_AGENT_PAYLOAD_MODE=multipart
SUBMIT_AGENT_TIMEOUT_SECONDS=20
SUBMIT_AGENT_RETRIES=2
SUBMIT_AGENT_INCLUDE_SCREENSHOTS=true

# Amethyst history (optional)
AMETHYST_HISTORY_URL=
